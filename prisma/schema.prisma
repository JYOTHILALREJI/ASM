generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin") // "super_admin" or "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications    Notification[]
  deleteRequests  DeleteRequest[] @relation("RequestedBy")
  reviewedRequests DeleteRequest[] @relation("ReviewedBy")
  warnings        Warning[]
  fines           Fine[]
}

model Employee {
  id              String   @id @default(cuid())
  fullName        String
  employeeId      String   @unique
  nationality     String?
  dateOfBirth     DateTime?
  phone           String?
  email           String?
  address         String?
  emergencyContact String?
  position        String?
  joinDate        DateTime?
  companyName     String?
  passportNumber  String?
  passportStatus  String?
  idNumber        String?
  idStatus        String?
  currentSite     String?
  rating          Float    @default(0)
  status          String   @default("active") // "active", "deleted", "pending_deletion"
  photo           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendance     Attendance[]
  warnings       Warning[]
  fines          Fine[]
  deleteRequests DeleteRequest[]
}

model Site {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Attendance {
  id            String   @id @default(cuid())
  employeeId    String
  date          String   // YYYY-MM-DD format
  status        String   @default("not_marked") // "present", "absent", "no_site", "overtime", "not_marked"
  overtimeHours Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "request", "warning", "fine"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Warning {
  id             String   @id @default(cuid())
  employeeId     String
  reason         String
  isAutoGenerated Boolean  @default(false)
  absentDates    String?  // JSON string of dates
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])
  createdById String
}

model Fine {
  id         String   @id @default(cuid())
  employeeId String
  reason     String
  amount     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])
  createdById String
}

model DeleteRequest {
  id          String   @id @default(cuid())
  employeeId  String
  requestedBy String
  reason      String?
  status      String   @default("pending") // "pending", "approved", "rejected"
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee   Employee  @relation(fields: [employeeId], references: [id])
  requested  User      @relation("RequestedBy", fields: [requestedBy], references: [id])
  reviewed   User?     @relation("ReviewedBy", fields: [reviewedBy], references: [id])
}
