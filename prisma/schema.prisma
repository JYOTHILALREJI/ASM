generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin") // "super_admin" or "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications         Notification[]
  leaveRequestsCreated  LeaveRequest[]  @relation("CreatedBy")
  leaveRequestsReviewed LeaveRequest[]  @relation("ReviewedBy")
  cancellationRequestsCreated CancellationRequest[] @relation("RequestedBy")
  cancellationRequestsReviewed CancellationRequest[] @relation("ReviewedBy")
  warnings              Warning[]
  fines                 Fine[]
}

model Employee {
  id              String   @id @default(cuid())
  fullName        String
  employeeId      String   @unique
  nationality     String?
  dateOfBirth     DateTime?
  phone           String?
  email           String?
  address         String?
  emergencyContact String?
  position        String?
  joinDate        DateTime?
  companyName     String?
  passportNumber  String?
  passportStatus  String?
  idNumber        String?
  idStatus        String?
  currentSite     String?
  rating          Float    @default(0)
  status          String   @default("active") // "active", "deleted", "pending_deletion"
  photo           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendance         Attendance[]
  warnings           Warning[]
  fines              Fine[]
  leaveRequests      LeaveRequest[]
  cancellationRequests CancellationRequest[]
}

model Site {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Attendance {
  id            String   @id @default(cuid())
  employeeId    String
  date          String   // YYYY-MM-DD format
  status        String   @default("not_marked") // "present", "absent", "no_site", "overtime", "not_marked"
  overtimeHours Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "request", "warning", "fine"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Warning {
  id             String   @id @default(cuid())
  employeeId     String
  reason         String
  isAutoGenerated Boolean  @default(false)
  absentDates    String?  // JSON string of dates
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])
  createdById String
}

model Fine {
  id         String   @id @default(cuid())
  employeeId String
  reason     String
  amount     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])
  createdById String
}

// NEW: Leave Request Model
model LeaveRequest {
  id          String   @id @default(cuid())
  employeeId  String
  leaveType   String   // "casual", "sick", "annual", "emergency", "marriage", "other"
  startDate   DateTime
  endDate     DateTime
  totalDays   Int
  reason      String
  status      String   @default("pending") // "pending", "approved", "rejected"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reviewedAt  DateTime?
  
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdBy   User     @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String
  reviewedBy  User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedById String?

  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
}

// NEW: Cancellation Request (employee deletion) – replaces old DeleteRequest
model CancellationRequest {
  id          String   @id @default(cuid())
  employeeId  String
  reason      String?
  status      String   @default("pending") // "pending", "approved", "rejected"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reviewedAt  DateTime?

  employee   Employee @relation(fields: [employeeId], references: [id])
  requestedBy User    @relation("RequestedBy", fields: [requestedById], references: [id])
  requestedById String
  reviewedBy  User?   @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedById String?

  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
}